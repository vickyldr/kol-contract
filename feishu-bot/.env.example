# 复制为 .env 并填好（用 pm2/systemd 时把这些设成环境变量）

# 飞书应用凭证（开放平台 → 你的应用 → 凭证与基础信息）
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx

# 事件订阅页的 Verification Token（必填，用于校验来源）
FEISHU_VERIFICATION_TOKEN=xxx
# 如果你在事件订阅里开了加密，填 Encrypt Key；没开就留空
FEISHU_ENCRYPT_KEY=

# 飞书国内默认即可；Lark 国际版改成 https://open.larksuite.com
FEISHU_BASE=https://open.feishu.cn

# 千问（用你的国内百炼 Key；国际站 Key 把 BASE 改成 https://dashscope-intl.aliyuncs.com）
QWEN_KEY=sk-xxx
QWEN_BASE=https://dashscope.aliyuncs.com
QWEN_MODEL=qwen-plus

# 监听端口（nginx 反代到这个端口）
PORT=3000
